# ─── Domaine ───────────────────────────────────────────────
# Domaine racine du lab. Crée un enregistrement DNS wildcard :
#   *.lab.example.com  A  <IP_DU_SERVEUR>
LAB_DOMAIN=lab.example.com

# ─── Let's Encrypt ─────────────────────────────────────────
ACME_EMAIL=mkrief@itrust.fr

# ─── Dashboard Traefik (basic auth) ────────────────────────
# Générer la valeur avec :
#   htpasswd -nbB admin 'TON_MOT_DE_PASSE'
# Doubler les '$' -> '$$' si tu colles dans un fichier compose,
# mais ici (lu via .env) garde la valeur telle quelle.
TRAEFIK_DASHBOARD_AUTH=
